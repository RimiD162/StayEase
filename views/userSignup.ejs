<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="Create your Stay-Ease account to explore 800+ verified stays across hotels, lodges, and rentals.">
  <link rel="stylesheet" href="/css/global.css">
  <link rel="stylesheet" href="/css/auth.css">
  <title>Create Account — Stay-Ease</title>
</head>
<body class="auth-body">

  <div class="auth-split">

    <!-- ===== Left Decorative Panel ===== -->
    <div class="auth-panel" style="background-image: linear-gradient(160deg,rgba(10,191,138,0.78),rgba(26,31,54,0.82)), url('https://images.unsplash.com/photo-1476514525535-07fb3b4ae5f1?w=900&q=80&fit=crop'); background-size: cover; animation: none;">
      <a href="/" class="auth-panel-logo">Stay<span>Ease</span></a>

      <div class="auth-panel-content">
        <h1 class="auth-panel-title">Join<br><span class="highlight">Stay-Ease</span></h1>
        <p class="auth-panel-text">Create your free account and unlock access to the best stays around.</p>

        <div class="auth-panel-benefits">
          <div class="auth-benefit">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
            Access 800+ verified stays
          </div>
          <div class="auth-benefit">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
            Save your favorite properties
          </div>
          <div class="auth-benefit">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
            Get exclusive member deals
          </div>
          <div class="auth-benefit">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
            Quick &amp; passwordless login
          </div>
        </div>
      </div>
    </div>

    <!-- ===== Right Form Panel ===== -->
    <div class="auth-form-panel">
      <div class="auth-form-wrapper" style="max-width:500px;">

        <a href="/" class="auth-mobile-logo">Stay<span>Ease</span></a>

        <div class="auth-header">
          <h2 class="auth-title">Create Account</h2>
          <p class="auth-subtitle">Already have an account? <a href="/user/login">Sign In &rarr;</a></p>
        </div>

        <!-- Progress Bar -->
        <div class="signup-progress">
          <div class="signup-progress-info">
            <span class="signup-progress-label">Profile Completion</span>
            <span class="signup-progress-pct" id="progress-pct">0%</span>
          </div>
          <div class="signup-progress-track">
            <div class="signup-progress-fill" id="progress-fill"></div>
          </div>
        </div>

        <% if (typeof error !== 'undefined' && error) { %>
        <div class="auth-alert auth-alert-error">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
          <%= error %>
        </div>
        <% } %>

        <form id="signup-form" class="auth-form" action="/user/signup" method="POST">
          <input type="hidden" name="avatar" id="avatar-data" value="">

          <!-- Avatar Upload -->
          <div class="form-group" id="avatar-group">
            <div class="avatar-upload" id="avatar-upload-zone">
              <div class="avatar-preview-box">
                <img id="avatar-preview-img" alt="Avatar Preview">
                <svg id="avatar-placeholder" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
              </div>
              <div class="avatar-upload-text">
                <span class="avatar-upload-title">Profile Photo (Optional)</span>
                <span class="avatar-upload-hint">Click to upload JPG or PNG (Max 2MB)</span>
              </div>
            </div>
            <input type="file" id="avatar-file-input" accept="image/*" style="display:none;">
            <div class="field-error">Invalid image file</div>
          </div>

          <!-- Row 1: Full Name + Username -->
          <div class="form-group-row">
            <div class="form-group" id="fullname-group">
              <div class="input-wrapper">
                <svg class="input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                <input type="text" class="form-input" id="fullname-input" name="fullName" placeholder=" " required value="<%= typeof oldValues !== 'undefined' && oldValues.fullName ? oldValues.fullName : '' %>">
                <label class="form-label" for="fullname-input">Full Name *</label>
                <div class="input-focus-line"></div>
              </div>
              <div class="field-error">Full name is required</div>
            </div>

            <div class="form-group" id="username-group">
              <div class="input-wrapper">
                <svg class="input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="4"/><path d="M16 8v5a3 3 0 0 0 6 0V12a10 10 0 1 0-3.92 7.94"/></svg>
                <input type="text" class="form-input" id="username-input" name="username" placeholder=" " required autocomplete="username" style="padding-right:100px;" value="<%= typeof oldValues !== 'undefined' && oldValues.username ? oldValues.username : '' %>">
                <label class="form-label" for="username-input">Username *</label>
                <div class="input-focus-line"></div>
                <div class="username-status" id="username-status"></div>
              </div>
              <div class="field-error">Lowercase letters, numbers, underscores only</div>
            </div>
          </div>

          <!-- Row 2: Email + Phone -->
          <div class="form-group-row">
            <div class="form-group" id="email-group">
              <div class="input-wrapper">
                <svg class="input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                <input type="email" class="form-input" id="email-input" name="email" placeholder=" " required value="<%= typeof oldValues !== 'undefined' && oldValues.email ? oldValues.email : '' %>">
                <label class="form-label" for="email-input">Email *</label>
                <div class="input-focus-line"></div>
              </div>
              <div class="field-error">A valid email is required</div>
            </div>

            <div class="form-group" id="phone-group">
              <div class="input-wrapper">
                <svg class="input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                <input type="tel" class="form-input" id="phone-input" name="phone" placeholder=" " required value="<%= typeof oldValues !== 'undefined' && oldValues.phone ? oldValues.phone : '' %>">
                <label class="form-label" for="phone-input">Phone *</label>
                <div class="input-focus-line"></div>
              </div>
              <div class="field-error">Phone number is required</div>
            </div>
          </div>

          <!-- Row 3: Gender + Date of Birth -->
          <div class="form-group-row">
            <div class="form-group" id="gender-group">
              <div class="gender-group">
                <span class="gender-group-label">Gender *</span>
                <div class="gender-pills">
                  <div class="gender-pill">
                    <input type="radio" id="gender-male" name="gender" value="Male" required <%= typeof oldValues !== 'undefined' && oldValues.gender === 'Male' ? 'checked' : '' %>>
                    <label for="gender-male">Male</label>
                  </div>
                  <div class="gender-pill">
                    <input type="radio" id="gender-female" name="gender" value="Female" <%= typeof oldValues !== 'undefined' && oldValues.gender === 'Female' ? 'checked' : '' %>>
                    <label for="gender-female">Female</label>
                  </div>
                  <div class="gender-pill">
                    <input type="radio" id="gender-other" name="gender" value="Other" <%= typeof oldValues !== 'undefined' && oldValues.gender === 'Other' ? 'checked' : '' %>>
                    <label for="gender-other">Other</label>
                  </div>
                </div>
              </div>
              <div class="field-error">Please select a gender</div>
            </div>

            <div class="form-group" id="dob-group">
              <div class="input-wrapper">
                <svg class="input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                <input type="date" class="form-input" id="dob-input" name="dateOfBirth" placeholder=" " value="<%= typeof oldValues !== 'undefined' && oldValues.dateOfBirth ? oldValues.dateOfBirth : '' %>" style="padding-right:16px;">
                <label class="form-label" for="dob-input" style="top:0;transform:translateY(-50%) scale(0.85);background:var(--bg-card);left:12px;font-weight:600;color:var(--text-mid);">Date of Birth</label>
                <div class="input-focus-line"></div>
              </div>
            </div>
          </div>

          <!-- Row 4: City -->
          <div class="form-group" id="city-group">
            <div class="input-wrapper">
              <svg class="input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
              <input type="text" class="form-input" id="city-input" name="city" placeholder=" " value="<%= typeof oldValues !== 'undefined' && oldValues.city ? oldValues.city : '' %>">
              <label class="form-label" for="city-input">City</label>
              <div class="input-focus-line"></div>
            </div>
          </div>

          <!-- Terms -->
          <div class="terms-row">
            <input type="checkbox" id="terms-check" required>
            <label for="terms-check">I agree to the <a href="#">Terms of Service</a> and <a href="#">Privacy Policy</a></label>
          </div>

          <!-- Submit -->
          <button type="submit" class="btn-auth" disabled>
            Create Account
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"/><path d="M12 5l7 7-7 7"/></svg>
          </button>

          <div class="auth-links">
            <a href="/user/login">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5"/><path d="M12 19l-7-7 7-7"/></svg>
              Already have an account? Sign In
            </a>
          </div>

        </form>
      </div>
    </div>
  </div>

  <script src="/js/auth.js"></script>
  
  <script>
    // Lazy load fade-in
    document.querySelectorAll('img').forEach(img => {
      if (img.complete) {
        img.classList.add('loaded');
      } else {
        img.addEventListener('load', () => img.classList.add('loaded'));
        img.addEventListener('error', () => {
          img.src = 'https://images.unsplash.com/photo-1566073771259-6a8506099945?w=800&q=80&fit=crop';
          img.classList.add('loaded');
        });
      }
    });
  </script>
</body>
</html>
