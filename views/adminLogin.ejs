<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="Admin login — Stay-Ease administration portal. Restricted access for authorized personnel.">
  <link rel="stylesheet" href="/css/global.css">
  <link rel="stylesheet" href="/css/auth.css">
  <title>Admin Sign In — Stay-Ease</title>
</head>
<body class="admin-auth-body" style="background-image: linear-gradient(135deg,rgba(26,31,54,0.96),rgba(26,31,54,0.92)), url('https://images.unsplash.com/photo-1590490360182-c33d57733427?w=1400&q=80&fit=crop'); background-size: cover; background-attachment: fixed;">

  <div class="admin-auth-card">

    <!-- Icon + Badge -->
    <div class="admin-auth-icon">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
        <rect x="9" y="9" width="6" height="5" rx="1"/>
        <path d="M12 9V7"/>
      </svg>
    </div>
    <div class="admin-auth-badge"><span>Admin Portal</span></div>

    <h1 class="admin-auth-title">Administrator Sign In</h1>
    <p class="admin-auth-subtitle">Restricted access — authorized personnel only</p>

    <% if (typeof error !== 'undefined' && error) { %>
    <div class="auth-alert auth-alert-error">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
      <%= error %>
    </div>
    <% } %>

    <% if (typeof success !== 'undefined' && success) { %>
    <div class="auth-alert auth-alert-success">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
      <%= success %>
    </div>
    <% } %>

    <form id="login-form" class="auth-form" action="/admin/login" method="POST">

      <!-- Username -->
      <div class="form-group" id="username-group">
        <div class="input-wrapper">
          <svg class="input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
          <input type="text" class="form-input" id="admin-username" name="username" placeholder=" " required autocomplete="username" value="<%= typeof oldValues !== 'undefined' && oldValues.username ? oldValues.username : '' %>">
          <label class="form-label" for="admin-username">Admin Username</label>
          <div class="input-focus-line"></div>
        </div>
        <div class="field-error">Username is required</div>
      </div>

      <!-- Email -->
      <div class="form-group" id="email-group">
        <div class="input-wrapper">
          <svg class="input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          <input type="email" class="form-input" id="admin-email" name="email" placeholder=" " required autocomplete="email" value="<%= typeof oldValues !== 'undefined' && oldValues.email ? oldValues.email : '' %>">
          <label class="form-label" for="admin-email">Admin Email</label>
          <div class="input-focus-line"></div>
        </div>
        <div class="field-error">A valid email is required</div>
      </div>

      <!-- Submit -->
      <button type="submit" class="btn-auth">
        Access Dashboard
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"/><path d="M12 5l7 7-7 7"/></svg>
      </button>

    </form>

    <div class="admin-auth-links">
      <a href="/">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5"/><path d="M12 19l-7-7 7-7"/></svg>
        Return to Landing
      </a>
      <a href="/admin/signup">Need access? Register as admin</a>
    </div>

    <!-- Security Badge -->
    <div class="admin-security-badge">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
      Secure Admin Session • Stay-Ease v1.0
    </div>

  </div>

  <script src="/js/auth.js"></script>
  
  <script>
    // Lazy load fade-in
    document.querySelectorAll('img').forEach(img => {
      if (img.complete) {
        img.classList.add('loaded');
      } else {
        img.addEventListener('load', () => img.classList.add('loaded'));
        img.addEventListener('error', () => {
          img.src = 'https://images.unsplash.com/photo-1566073771259-6a8506099945?w=800&q=80&fit=crop';
          img.classList.add('loaded');
        });
      }
    });
  </script>
</body>
</html>
