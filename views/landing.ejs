<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="Welcome to Stay-Ease - Select your portal to continue.">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Outfit:wght@500;700;900&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/landing.css">
  <title>Welcome to Stay-Ease — Simplified Stays</title>
</head>
<body>

  <div class="landing-container">
    <!-- Premium Dark Backdrop Blur Overlay -->
    <div class="background-overlay" aria-hidden="true"></div>

    <!-- Center Brand Header -->
    <header class="brand-overlay">
      <div class="logo-container">
        <h1 class="logo-text">Stay<span>Ease</span></h1>
        <p class="brand-tagline">Your perfect stay, simplified</p>
      </div>
    </header>

    <!-- Cards Wrapper -->
    <div class="cards-wrapper">
      
      <!-- LEFT CARD: Admin Portal -->
      <section class="portal-card card-admin" onclick="navigateTo('/admin/login')">
        <div class="card-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
            <line x1="9" y1="3" x2="9" y2="21"/>
            <line x1="15" y1="3" x2="15" y2="21"/>
            <line x1="3" y1="9" x2="21" y2="9"/>
            <line x1="3" y1="15" x2="21" y2="15"/>
          </svg>
        </div>
        <div>
          <h2 class="card-title">Admin Portal</h2>
          <p class="card-subtitle">Manage listings, users & overall content dashboard.</p>
        </div>
        <a href="/admin/login" class="panel-btn admin-btn" onclick="event.stopPropagation();">Enter as Admin</a>
      </section>

      <!-- Center OR Divider -->
      <div class="divider-or" aria-hidden="true">
        <span>OR</span>
      </div>

      <!-- RIGHT CARD: User Portal -->
      <section class="portal-card card-user" onclick="navigateTo('/user/login')">
        <div class="card-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
            <circle cx="9" cy="7" r="4"/>
            <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
            <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
          </svg>
        </div>
        <div>
          <h2 class="card-title">Explore & Stay</h2>
          <p class="card-subtitle">Discover premium hotels, nature lodges & vacation rentals.</p>
        </div>
        <a href="/user/login" class="panel-btn user-btn" onclick="event.stopPropagation();">Enter as User</a>
      </section>

    </div>
  </div>

  <script>
    function navigateTo(url) {
      document.body.style.opacity = '0';
      document.body.style.transition = 'opacity 0.4s ease';
      setTimeout(() => {
        window.location.href = url;
      }, 400);
    }
  </script>
</body>
</html>
