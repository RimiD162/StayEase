<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="Your Stay-Ease profile — manage your personal information and account settings.">
  <link rel="stylesheet" href="/css/global.css">
  <link rel="stylesheet" href="/css/home.css">
  <link rel="stylesheet" href="/css/profile.css">
  <title>My Profile — Stay-Ease</title>
</head>
<body>

  <!-- ===== Navbar ===== -->
  <nav class="navbar" id="main-navbar">
    <a href="/home" class="navbar-logo">Stay<span>Ease</span></a>
    <div class="navbar-links">
      <a href="/home" class="navbar-link">Home</a>
      <a href="/home/hotel" class="navbar-link">Hotels</a>
      <a href="/home/lodges" class="navbar-link">Lodges</a>
      <a href="/home/rentals" class="navbar-link">Rentals</a>
    </div>
    <% if (user) { %>
    <div class="navbar-user" id="navbar-user" onclick="toggleDropdown()">
      <div class="navbar-avatar">
        <% if (user.avatar) { %><img src="<%= user.avatar %>" alt=""><% } else { %><%= user.fullName ? user.fullName.charAt(0).toUpperCase() : 'U' %><% } %>
      </div>
      <span class="navbar-username"><%= user.fullName ? user.fullName.split(' ')[0] : 'User' %></span>
      <svg class="navbar-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
      <div class="navbar-dropdown" id="navbar-dropdown">
        <a href="/profile" class="navbar-dropdown-item"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>My Profile</a>
        <div class="navbar-dropdown-divider"></div>
        <form action="/user/logout" method="POST" style="margin:0;"><button type="submit" class="navbar-dropdown-item"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>Logout</button></form>
      </div>
    </div>
    <% } %>
    <button class="navbar-toggle" onclick="document.querySelector('.navbar-links').classList.toggle('show-mobile')"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg></button>
  </nav>

  <div class="profile-page">
    <div class="profile-container">

      <!-- ===== Left Sidebar ===== -->
      <aside class="profile-sidebar">
        <div class="profile-sidebar-header">
          <div class="profile-avatar-wrap">
            <% if (profileDetails.avatar) { %>
              <img src="<%= profileDetails.avatar %>" alt="<%= profileDetails.fullName %>">
            <% } else { %>
              <div class="profile-avatar-placeholder">
                <%= profileDetails.fullName ? profileDetails.fullName.charAt(0).toUpperCase() : 'U' %>
              </div>
            <% } %>
          </div>
          <h2 class="profile-sidebar-name"><%= profileDetails.fullName || 'User' %></h2>
          <p class="profile-sidebar-username">@<%= profileDetails.username || '' %></p>
          <p class="profile-sidebar-email"><%= profileDetails.email || '' %></p>
        </div>

        <div class="profile-sidebar-info">
          <% if (profileDetails.phone) { %>
          <div class="profile-info-item">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            <%= profileDetails.phone %>
          </div>
          <% } %>
          <% if (profileDetails.city) { %>
          <div class="profile-info-item">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            <%= profileDetails.city %>
          </div>
          <% } %>
          <% if (profileDetails.gender) { %>
          <div class="profile-info-item">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
            <%= profileDetails.gender %>
          </div>
          <% } %>
          <div class="profile-info-item">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
            Joined <%= profileDetails.createdAt ? new Date(profileDetails.createdAt).toLocaleDateString('en-IN', { year: 'numeric', month: 'short', day: 'numeric' }) : 'Unknown' %>
          </div>
        </div>

        <div class="profile-sidebar-actions">
          <form action="/user/logout" method="POST">
            <button type="submit" class="btn btn-outline btn-block btn-sm">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:16px;height:16px;"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
              Logout
            </button>
          </form>
        </div>
      </aside>

      <!-- ===== Right Content ===== -->
      <section class="profile-content">
        <div class="profile-content-header">
          <h2 class="profile-content-title">Personal Information</h2>
        </div>

        <form class="profile-form" action="/profile" method="POST">
          <input type="hidden" name="avatar" id="profile-avatar-data" value="<%= profileDetails.avatar || '' %>">

          <% if (typeof success !== 'undefined' && success) { %>
          <div class="profile-alert-success">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            <%= success %>
          </div>
          <% } %>

          <!-- Avatar Upload -->
          <div class="profile-avatar-upload" id="profile-avatar-zone" onclick="document.getElementById('profile-avatar-file').click()">
            <div class="profile-avatar-upload-preview">
              <% if (profileDetails.avatar) { %>
              <img id="profile-avatar-preview" src="<%= profileDetails.avatar %>" alt="Avatar">
              <% } else { %>
              <svg id="profile-avatar-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
              <img id="profile-avatar-preview" style="display:none;" alt="Avatar">
              <% } %>
            </div>
            <div>
              <div style="font-size:14px;font-weight:600;color:var(--text-dark);">Update Profile Photo</div>
              <div style="font-size:12px;color:var(--text-soft);">Click to upload (Max 2MB)</div>
            </div>
          </div>
          <input type="file" id="profile-avatar-file" accept="image/*" style="display:none;">

          <!-- Row: Full Name, Phone -->
          <div class="profile-form-row">
            <div class="profile-form-group">
              <label class="profile-form-label">Full Name</label>
              <input type="text" class="profile-form-input" name="fullName" value="<%= profileDetails.fullName || '' %>" required>
            </div>
            <div class="profile-form-group">
              <label class="profile-form-label">Phone</label>
              <input type="tel" class="profile-form-input" name="phone" value="<%= profileDetails.phone || '' %>" required>
            </div>
          </div>

          <!-- Row: Username (readonly), Email (readonly) -->
          <div class="profile-form-row">
            <div class="profile-form-group">
              <label class="profile-form-label">Username</label>
              <input type="text" class="profile-form-input" value="<%= profileDetails.username || '' %>" readonly>
            </div>
            <div class="profile-form-group">
              <label class="profile-form-label">Email</label>
              <input type="email" class="profile-form-input" value="<%= profileDetails.email || '' %>" readonly>
            </div>
          </div>

          <!-- Row: Gender, Date of Birth -->
          <div class="profile-form-row">
            <div class="profile-form-group">
              <label class="profile-form-label">Gender</label>
              <div class="profile-gender-pills">
                <div class="profile-gender-pill">
                  <input type="radio" id="pg-male" name="gender" value="Male" <%= profileDetails.gender === 'Male' ? 'checked' : '' %>>
                  <label for="pg-male">Male</label>
                </div>
                <div class="profile-gender-pill">
                  <input type="radio" id="pg-female" name="gender" value="Female" <%= profileDetails.gender === 'Female' ? 'checked' : '' %>>
                  <label for="pg-female">Female</label>
                </div>
                <div class="profile-gender-pill">
                  <input type="radio" id="pg-other" name="gender" value="Other" <%= profileDetails.gender === 'Other' ? 'checked' : '' %>>
                  <label for="pg-other">Other</label>
                </div>
              </div>
            </div>
            <div class="profile-form-group">
              <label class="profile-form-label">Date of Birth</label>
              <input type="date" class="profile-form-input" name="dateOfBirth" value="<%= profileDetails.dateOfBirth ? new Date(profileDetails.dateOfBirth).toISOString().split('T')[0] : '' %>">
            </div>
          </div>

          <!-- City -->
          <div class="profile-form-group">
            <label class="profile-form-label">City</label>
            <input type="text" class="profile-form-input" name="city" value="<%= profileDetails.city || '' %>">
          </div>

          <div class="profile-form-actions">
            <a href="/home" class="btn btn-outline btn-sm">Cancel</a>
            <button type="submit" class="btn btn-teal btn-sm">Save Changes</button>
          </div>
        </form>
      </section>
    </div>
  </div>

  <script>
    window.addEventListener('scroll',()=>{document.getElementById('main-navbar').classList.toggle('scrolled',window.scrollY>10);});
    function toggleDropdown(){const u=document.getElementById('navbar-user'),d=document.getElementById('navbar-dropdown');if(u&&d){u.classList.toggle('open');d.classList.toggle('show');}}
    document.addEventListener('click',(e)=>{const u=document.getElementById('navbar-user');if(u&&!u.contains(e.target)){u.classList.remove('open');const d=document.getElementById('navbar-dropdown');if(d)d.classList.remove('show');}});

    // Avatar upload
    document.getElementById('profile-avatar-file')?.addEventListener('change', function() {
      const file = this.files[0];
      if (!file || file.size > 2*1024*1024 || !file.type.startsWith('image/')) return;
      const reader = new FileReader();
      reader.onload = function(e) {
        const preview = document.getElementById('profile-avatar-preview');
        const icon = document.getElementById('profile-avatar-icon');
        if (preview) { preview.src = e.target.result; preview.style.display = 'block'; }
        if (icon) icon.style.display = 'none';
        document.getElementById('profile-avatar-data').value = e.target.result;
      };
      reader.readAsDataURL(file);
    });
  </script>
  
  <script>
    // Lazy load fade-in
    document.querySelectorAll('img').forEach(img => {
      if (img.complete) {
        img.classList.add('loaded');
      } else {
        img.addEventListener('load', () => img.classList.add('loaded'));
        img.addEventListener('error', () => {
          img.src = 'https://images.unsplash.com/photo-1566073771259-6a8506099945?w=800&q=80&fit=crop';
          img.classList.add('loaded');
        });
      }
    });
  </script>
</body>
</html>
