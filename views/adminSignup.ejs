<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="Register as a Stay-Ease administrator. Access code required.">
  <link rel="stylesheet" href="/css/global.css">
  <link rel="stylesheet" href="/css/auth.css">
  <title>Admin Registration — Stay-Ease</title>
</head>
<body class="admin-auth-body" style="background-image: linear-gradient(135deg,rgba(26,31,54,0.96),rgba(26,31,54,0.92)), url('https://images.unsplash.com/photo-1590490360182-c33d57733427?w=1400&q=80&fit=crop'); background-size: cover; background-attachment: fixed;">

  <div class="admin-auth-card">

    <div class="admin-auth-icon">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
        <circle cx="8.5" cy="7" r="4"/>
        <line x1="20" y1="8" x2="20" y2="14"/>
        <line x1="23" y1="11" x2="17" y2="11"/>
      </svg>
    </div>
    <div class="admin-auth-badge"><span>Admin Registration</span></div>

    <h1 class="admin-auth-title">Create Admin Account</h1>
    <p class="admin-auth-subtitle">An access code is required to register as administrator</p>

    <% if (typeof error !== 'undefined' && error) { %>
    <div class="auth-alert auth-alert-error">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
      <%= error %>
    </div>
    <% } %>

    <form id="login-form" class="auth-form" action="/admin/signup" method="POST">

      <!-- Full Name -->
      <div class="form-group">
        <div class="input-wrapper">
          <svg class="input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
          <input type="text" class="form-input" name="fullName" placeholder=" " required value="<%= typeof oldValues !== 'undefined' && oldValues.fullName ? oldValues.fullName : '' %>">
          <label class="form-label">Full Name *</label>
          <div class="input-focus-line"></div>
        </div>
      </div>

      <!-- Username -->
      <div class="form-group">
        <div class="input-wrapper">
          <svg class="input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="4"/><path d="M16 8v5a3 3 0 0 0 6 0V12a10 10 0 1 0-3.92 7.94"/></svg>
          <input type="text" class="form-input" name="username" placeholder=" " required value="<%= typeof oldValues !== 'undefined' && oldValues.username ? oldValues.username : '' %>">
          <label class="form-label">Admin Username *</label>
          <div class="input-focus-line"></div>
        </div>
      </div>

      <!-- Email -->
      <div class="form-group">
        <div class="input-wrapper">
          <svg class="input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          <input type="email" class="form-input" name="email" placeholder=" " required value="<%= typeof oldValues !== 'undefined' && oldValues.email ? oldValues.email : '' %>">
          <label class="form-label">Email *</label>
          <div class="input-focus-line"></div>
        </div>
      </div>

      <!-- Phone -->
      <div class="form-group">
        <div class="input-wrapper">
          <svg class="input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          <input type="tel" class="form-input" name="phone" placeholder=" " value="<%= typeof oldValues !== 'undefined' && oldValues.phone ? oldValues.phone : '' %>">
          <label class="form-label">Phone (Optional)</label>
          <div class="input-focus-line"></div>
        </div>
      </div>

      <!-- Secret Code -->
      <div class="form-group">
        <div class="input-wrapper">
          <svg class="input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
          <input type="text" class="form-input" name="secretCode" placeholder=" " required>
          <label class="form-label">Access Code *</label>
          <div class="input-focus-line"></div>
        </div>
      </div>

      <!-- Submit -->
      <button type="submit" class="btn-auth">
        Register Admin Account
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"/><path d="M12 5l7 7-7 7"/></svg>
      </button>

    </form>

    <div class="admin-auth-links">
      <a href="/admin/login">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5"/><path d="M12 19l-7-7 7-7"/></svg>
        Already registered? Sign In
      </a>
      <a href="/">Return to Landing</a>
    </div>

    <div class="admin-security-badge">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
      Secure Admin Registration • Stay-Ease v1.0
    </div>

  </div>

  <script src="/js/auth.js"></script>
  
  <script>
    // Lazy load fade-in
    document.querySelectorAll('img').forEach(img => {
      if (img.complete) {
        img.classList.add('loaded');
      } else {
        img.addEventListener('load', () => img.classList.add('loaded'));
        img.addEventListener('error', () => {
          img.src = 'https://images.unsplash.com/photo-1566073771259-6a8506099945?w=800&q=80&fit=crop';
          img.classList.add('loaded');
        });
      }
    });
  </script>
</body>
</html>
