<body>

    <!-- ===== Particles Background ===== -->
    <div class="particles" id="particles" aria-hidden="true"></div>

    <!-- ===== Navbar ===== -->
    <nav class="navbar" id="navbar">
        <div class="nav-container">
            <a href="/home" class="nav-logo" id="nav-logo">
                <span class="logo-text">Stay<span class="logo-accent">Ease</span></span>
            </a>

            <div class="nav-links" id="nav-links">
                <a href="/home" class="nav-link" id="nav-home">Home</a>
                <a href="/home/hotel" class="nav-link active" id="nav-hotels">Hotels</a>
                <a href="/home/Rentals" class="nav-link" id="nav-rentals">Rentals</a>
                <a href="/home/Lodges" class="nav-link" id="nav-lodges">Lodges</a>
            </div>

            <div class="nav-actions">
                <button class="btn-ghost" id="btn-login">Log In</button>
                <button class="btn-primary-sm" id="btn-signup">Get Started</button>
            </div>

            <button class="mobile-toggle" id="mobile-toggle" aria-label="Toggle navigation">
                <span></span><span></span><span></span>
            </button>
        </div>
    </nav>

    <!-- ===== Page Hero ===== -->
    <section class="page-hero" id="hotel-hero">
        <div class="page-hero-glow hotel-glow" aria-hidden="true"></div>

        <div class="page-hero-content fade-up">
            <div class="page-breadcrumb">
                <span class="breadcrumb-sep">›</span>
            </div>

            <h1 class="page-title">
                Luxury Stays,<br>
                <span class="gradient-text hotel-gradient">Unforgettable Experiences</span>
            </h1>

            <p class="page-subtitle">
                From boutique hideaways to five-star resorts — explore handpicked hotels that
                redefine comfort, elegance, and world-class hospitality.
            </p>

            </div>
        </div>
    </section>

    

    <!-- ===== Hotel Listings ===== -->
    

    <!-- ===== Why Choose Hotels ===== -->
    <section class="why-section" id="why-hotels">
        <div class="why-section-glow hotel-glow" aria-hidden="true"></div>
        <div class="why-container">
            <div class="why-header fade-up">
                <h2 class="why-title">Why Choose Our <span class="gradient-text hotel-gradient">Hotels</span></h2>
                <p class="why-subtitle">Every hotel on Stay-Ease is verified and curated for quality, ensuring you get
                    nothing but the best experience.</p>
            </div>

            <div class="why-grid">
                <div class="why-card hotel-card fade-up delay-1" id="why-hotel-1">
                    <h3>Verified Properties</h3>
                    <p>Every hotel is personally inspected and verified by our quality assurance team for your peace of
                        mind.</p>
                </div>
                <div class="why-card hotel-card fade-up delay-2" id="why-hotel-2">
                    <h3>Best Price Guarantee</h3>
                    <p>We match any lower price you find elsewhere. Book with confidence knowing you're getting the best
                        deal.</p>
                </div>
                <div class="why-card hotel-card fade-up delay-3" id="why-hotel-3">
                    <h3>Free Cancellation</h3>
                    <p>Plans change — we get it. Enjoy free cancellation up to 24 hours before check-in on most
                        bookings.</p>
                </div>
                <div class="why-card hotel-card fade-up delay-4" id="why-hotel-4">
                    <h3>24/7 Support</h3>
                    <p>Our dedicated support team is available around the clock to assist you with anything you need.</p>
                </div>
            </div>
        </div>
    </section>

