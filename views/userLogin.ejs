<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="Log in to Stay-Ease to explore hotels, nature lodges, and rentals.">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Outfit:wght@500;700;900&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/auth.css">
  <title>Log In — Stay-Ease</title>
</head>
<body class="auth-body user-theme">

  <div class="auth-container">
    <!-- ===== Decorative Left Panel ===== -->
    <div class="auth-sidebar">
      <a href="/" class="auth-sidebar-logo">
        Stay<span>Ease</span>
      </a>
      <div class="auth-sidebar-content">
        <h1 class="auth-sidebar-title">
          Welcome Back to<br>
          <span class="highlight">Explore & Stay</span>
        </h1>
        <p class="auth-sidebar-text">
          Access your account to seamlessly browse premium accommodations, review booked stays, or customize your profile.
        </p>
      </div>
      <div class="auth-sidebar-footer">
        &copy; 2026 Stay-Ease. All rights reserved.
      </div>
    </div>

    <!-- ===== Form Right Panel ===== -->
    <div class="auth-content">
      <div class="auth-card" id="auth-card-element">
        <div class="auth-header">
          <a href="/" class="auth-logo-mobile">
            Stay<span>Ease</span>
          </a>
          <h2 class="auth-title">Welcome Back</h2>
          <p class="auth-subtitle">New to Stay-Ease? <a href="/user/signup">Create an account &rarr;</a></p>
        </div>

        <!-- Success or Error Alerts -->
        <% if (typeof success !== 'undefined' && success) { %>
          <div class="alert-banner alert-banner-success">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
              <polyline points="22 4 12 14.01 9 11.01"/>
            </svg>
            <span><%= success %></span>
          </div>
        <% } %>
        
        <% if (typeof error !== 'undefined' && error) { %>
          <div class="alert-banner alert-banner-error" id="server-error-banner">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"/>
              <line x1="12" y1="8" x2="12" y2="12"/>
              <line x1="12" y1="16" x2="12.01" y2="16"/>
            </svg>
            <span><%= error %></span>
          </div>
        <% } %>

        <form id="user-login-form" class="auth-form" action="/user/login" method="POST">
          
          <!-- Username Input -->
          <div class="form-group" id="group-username">
            <div class="input-icon-wrapper">
              <div class="input-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M20 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                  <circle cx="9" cy="7" r="4"/>
                </svg>
              </div>
              <input type="text" class="form-input" id="username-input" name="username" placeholder=" " required autocomplete="username" value="<%= typeof oldValues !== 'undefined' ? oldValues.username : '' %>">
              <label class="form-label" for="username-input">Username</label>
              <div class="input-focus-line"></div>
            </div>
            <div class="error-msg">Please enter your username.</div>
          </div>

          <!-- Email Address Input -->
          <div class="form-group" id="group-email">
            <div class="input-icon-wrapper">
              <div class="input-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                  <polyline points="22,6 12,13 2,6"/>
                </svg>
              </div>
              <input type="email" class="form-input" id="email-input" name="email" placeholder=" " required autocomplete="email" value="<%= typeof oldValues !== 'undefined' ? oldValues.email : '' %>">
              <label class="form-label" for="email-input">Email Address</label>
              <div class="input-focus-line"></div>
            </div>
            <div class="error-msg">Please enter a valid email address.</div>
          </div>

          <!-- Actions: Remember Me -->
          <div class="form-actions-row">
            <label class="remember-me">
              <input type="checkbox" name="rememberMe" id="remember-me-checkbox">
              <span>Remember Me (7 Days)</span>
            </label>
          </div>

          <!-- Submit Button -->
          <button type="submit" class="btn-auth-submit">
            Log In as User
          </button>

          <!-- Back link -->
          <a href="/" class="auth-back-link">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <line x1="19" y1="12" x2="5" y2="12"/>
              <polyline points="12 19 5 12 12 5"/>
            </svg>
            Back to Home
          </a>
        </form>
      </div>
    </div>
  </div>

  <script>
    const form = document.getElementById('user-login-form');
    const card = document.getElementById('auth-card-element');
    const serverError = document.getElementById('server-error-banner');

    // Trigger shake animation on server error
    if (serverError) {
      card.classList.add('shake-field');
      setTimeout(() => card.classList.remove('shake-field'), 500);
    }

    form.addEventListener('submit', function(e) {
      let hasError = false;

      // Validate Username
      const usernameInput = document.getElementById('username-input');
      const groupUsername = document.getElementById('group-username');
      if (!usernameInput.value.trim()) {
        groupUsername.classList.add('has-error');
        hasError = true;
      } else {
        groupUsername.classList.remove('has-error');
      }

      // Validate Email
      const emailInput = document.getElementById('email-input');
      const groupEmail = document.getElementById('group-email');
      const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
      if (!emailInput.value.trim() || !emailRegex.test(emailInput.value.trim())) {
        groupEmail.classList.add('has-error');
        hasError = true;
      } else {
        groupEmail.classList.remove('has-error');
      }

      if (hasError) {
        e.preventDefault();
        card.classList.add('shake-field');
        setTimeout(() => card.classList.remove('shake-field'), 500);
      }
    });

    // Remove errors on input
    document.querySelectorAll('.form-input').forEach(input => {
      input.addEventListener('input', function() {
        this.closest('.form-group').classList.remove('has-error');
      });
    });
  </script>
</body>
</html>
