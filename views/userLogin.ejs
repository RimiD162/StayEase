<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="Log in to Stay-Ease to explore premium hotels, cozy lodges, and private rentals.">
  <link rel="stylesheet" href="/css/global.css">
  <link rel="stylesheet" href="/css/auth.css">
  <title>Sign In — Stay-Ease</title>
</head>
<body class="auth-body">

  <div class="auth-split">

    <!-- ===== Left Decorative Panel ===== -->
    <div class="auth-panel" style="background-image: linear-gradient(160deg,rgba(26,31,54,0.75),rgba(10,191,138,0.65)), url('https://images.unsplash.com/photo-1566073771259-6a8506099945?w=900&q=80&fit=crop'); background-size: cover; background-position: center; animation: none;">
      <a href="/" class="auth-panel-logo">Stay<span>Ease</span></a>

      <div class="auth-panel-content">
        <h1 class="auth-panel-title">Welcome Back,<br><span class="highlight">Traveler</span></h1>
        <p class="auth-panel-text">Sign in to access your saved stays, exclusive deals, and personalized travel recommendations.</p>
        <img src="https://images.unsplash.com/photo-1631049307264-da0ec9d70304?w=800&q=80&fit=crop" 
             style="border-radius:12px;width:180px;box-shadow:0 8px 32px rgba(0,0,0,0.3); margin: 24px auto 0 auto;"
             loading="lazy"
             onerror="this.src='https://images.unsplash.com/photo-1566073771259-6a8506099945?w=800&q=80&fit=crop'">
      </div>
    </div>

    <!-- ===== Right Form Panel ===== -->
    <div class="auth-form-panel">
      <div class="auth-form-wrapper">

        <a href="/" class="auth-mobile-logo">Stay<span>Ease</span></a>

        <div class="auth-header">
          <h2 class="auth-title">Sign In</h2>
          <p class="auth-subtitle">Enter your username and email to continue</p>
        </div>

        <% if (typeof error !== 'undefined' && error) { %>
        <div class="auth-alert auth-alert-error">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
          <%= error %>
        </div>
        <% } %>

        <% if (typeof success !== 'undefined' && success) { %>
        <div class="auth-alert auth-alert-success">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          <%= success %>
        </div>
        <% } %>

        <form id="login-form" class="auth-form" action="/user/login" method="POST">

          <!-- Username -->
          <div class="form-group" id="username-group">
            <div class="input-wrapper">
              <svg class="input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
              <input type="text" class="form-input" id="login-username" name="username" placeholder=" " required autocomplete="username" value="<%= typeof oldValues !== 'undefined' && oldValues.username ? oldValues.username : '' %>">
              <label class="form-label" for="login-username">Username</label>
              <div class="input-focus-line"></div>
            </div>
            <div class="field-error">Username is required</div>
          </div>

          <!-- Email -->
          <div class="form-group" id="email-group">
            <div class="input-wrapper">
              <svg class="input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
              <input type="email" class="form-input" id="login-email" name="email" placeholder=" " required autocomplete="email" value="<%= typeof oldValues !== 'undefined' && oldValues.email ? oldValues.email : '' %>">
              <label class="form-label" for="login-email">Email Address</label>
              <div class="input-focus-line"></div>
            </div>
            <div class="field-error">A valid email is required</div>
          </div>

          <!-- Remember Me -->
          <div class="form-actions">
            <label class="remember-label">
              <input type="checkbox" name="rememberMe" value="true">
              Remember me
            </label>
          </div>

          <!-- Submit -->
          <button type="submit" class="btn-auth">
            Login
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"/><path d="M12 5l7 7-7 7"/></svg>
          </button>

          <div class="auth-divider">or</div>

          <div class="auth-links">
            <a href="/user/signup">Create an account <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"/><path d="M12 5l7 7-7 7"/></svg></a>
            <a href="/">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5"/><path d="M12 19l-7-7 7-7"/></svg>
              Back to Home
            </a>
          </div>

        </form>
      </div>
    </div>
  </div>

  <script src="/js/auth.js"></script>
  
  <script>
    // Lazy load fade-in
    document.querySelectorAll('img').forEach(img => {
      if (img.complete) {
        img.classList.add('loaded');
      } else {
        img.addEventListener('load', () => img.classList.add('loaded'));
        img.addEventListener('error', () => {
          img.src = 'https://images.unsplash.com/photo-1566073771259-6a8506099945?w=800&q=80&fit=crop';
          img.classList.add('loaded');
        });
      }
    });
  </script>
</body>
</html>
